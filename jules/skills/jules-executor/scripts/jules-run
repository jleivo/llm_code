#!/usr/bin/env bash
# Wrapper that bootstraps a venv inside the skill directory and runs Python scripts.
# Usage:
#   jules-run run_plan.py <args>
#   jules-run jules_cli.py <args>
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${SCRIPT_DIR}/.venv"
REQUIREMENTS="${SCRIPT_DIR}/requirements.txt"

# Bootstrap venv if missing or requirements changed
if [ ! -f "${VENV_DIR}/bin/python3" ]; then
    echo "Creating venv at ${VENV_DIR}..." >&2
    python3 -m venv "${VENV_DIR}"
    "${VENV_DIR}/bin/pip" install --quiet --upgrade pip
    "${VENV_DIR}/bin/pip" install --quiet -r "${REQUIREMENTS}"
elif [ "${REQUIREMENTS}" -nt "${VENV_DIR}/.installed" ] 2>/dev/null; then
    echo "Updating dependencies..." >&2
    "${VENV_DIR}/bin/pip" install --quiet -r "${REQUIREMENTS}"
fi
touch "${VENV_DIR}/.installed"

# Run the requested script
if [ $# -eq 0 ]; then
    echo "Usage: jules-run <script.py> [args...]" >&2
    echo "  jules-run run_plan.py <plan-file> [--poll-once ...]" >&2
    echo "  jules-run jules_cli.py <command> [args...]" >&2
    exit 1
fi

SCRIPT="$1"
shift
exec "${VENV_DIR}/bin/python3" "${SCRIPT_DIR}/${SCRIPT}" "$@"
